NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SITE_URL=http://localhost:3000

# Admin area (server-only). The single Supabase Auth account allowed into
# /admin. Unset means nobody can sign in, so the gate fails closed.
ADMIN_EMAIL=

# Transactional email (server-only). Order emails are skipped when
# RESEND_API_KEY or EMAIL_FROM is missing, so payments still work without them.
RESEND_API_KEY=
EMAIL_FROM="Sombre <orders@yourdomain.com>"
SELLER_NOTIFICATION_EMAIL=
EMAIL_REPLY_TO=

# Checkout rate limiting (server-only). Shared Upstash Redis limiter. Set all
# three to enable the shared limiter across serverless instances; leave all
# three unset to use the in-memory fallback (fine for local development).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
RATE_LIMIT_HASH_SECRET=
